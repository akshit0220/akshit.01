import pandas as pd
import numpy as np
import re
from scipy.sparse import hstack, csr_matrix
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, confusion_matrix, classification_report
import matplotlib.pyplot as plt

data = pd.read_csv("emails.csv")

def extract_features(text):
    text = str(text)

    urls = re.findall(r'http[s]?://\S+|www\.\S+', text)
    url_count = len(urls)

    keywords = [
        "click", "verify", "winner", "free", "urgent",
        "account", "bank", "password", "offer",
        "login", "claim", "prize", "limited"
    ]

    keyword_count = 0
    for word in keywords:
        keyword_count += text.lower().count(word)

    email_length = len(text)

    return pd.Series([url_count, keyword_count, email_length])

data[["url_count", "keyword_count", "email_length"]] = data["email"].apply(extract_features)

print("\nFeature Analysis")
print("-" * 40)
print("Average URLs:", round(data["url_count"].mean(), 2))
print("Average Keywords:", round(data["keyword_count"].mean(), 2))
print("Average Email Length:", round(data["email_length"].mean(), 2))

vectorizer = TfidfVectorizer(
    stop_words="english",
    max_features=3000
)

text_features = vectorizer.fit_transform(data["email"])

extra_features = csr_matrix(
    data[["url_count", "keyword_count", "email_length"]].values
)

X = hstack([text_features, extra_features])

y = data["label"]

X_train, X_test, y_train, y_test = train_test_split(
    X,
    y,
    test_size=0.20,
    random_state=42
)

model = RandomForestClassifier(
    n_estimators=200,
    random_state=42
)

model.fit(X_train, y_train)

predictions = model.predict(X_test)

accuracy = accuracy_score(y_test, predictions)

print("\nAccuracy:", round(accuracy * 100, 2), "%")

print("\nClassification Report\n")
print(classification_report(y_test, predictions))

cm = confusion_matrix(y_test, predictions)

plt.figure(figsize=(6, 5))
plt.imshow(cm)
plt.title("Phishing Email Detection Confusion Matrix")
plt.colorbar()

labels = model.classes_

plt.xticks(range(len(labels)), labels)
plt.yticks(range(len(labels)), labels)

plt.xlabel("Predicted")
plt.ylabel("Actual")

for i in range(len(cm)):
    for j in range(len(cm)):
        plt.text(j, i, cm[i, j],
                 ha="center",
                 va="center")

plt.tight_layout()
plt.show()

while True:

    print("\n==============================")
    print("PHISHING EMAIL CHECKER")
    print("==============================")

    email_text = input("\nEnter Email Content:\n")

    url_count = len(
        re.findall(
            r'http[s]?://\S+|www\.\S+',
            email_text
        )
    )

    keyword_count = 0

    for word in [
        "click", "verify", "winner", "free", "urgent",
        "account", "bank", "password", "offer",
        "login", "claim", "prize", "limited"
    ]:
        keyword_count += email_text.lower().count(word)

    email_length = len(email_text)

    text_vector = vectorizer.transform([email_text])

    extra_vector = csr_matrix(
        [[url_count, keyword_count, email_length]]
    )

    final_input = hstack(
        [text_vector, extra_vector]
    )

    prediction = model.predict(final_input)[0]

    confidence = np.max(
        model.predict_proba(final_input)
    ) * 100

    print("\nURL Count:", url_count)
    print("Keyword Count:", keyword_count)
    print("Email Length:", email_length)

    print("\nPrediction:", prediction)
    print("Confidence:", round(confidence, 2), "%")

    if prediction.lower() == "phishing":
        print("Warning: Suspicious Email Detected")
    else:
        print("Email Appears Safe")

    choice = input("\nTest Another Email? (yes/no): ")

    if choice.lower() != "yes":
        break
