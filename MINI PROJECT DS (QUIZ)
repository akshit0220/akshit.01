 #include <stdio.h>
#include <string.h>

#define Q 5

// Structure for Question
struct Question {
    char ques[100];
    char optA[50], optB[50], optC[50], optD[50];
    char correct;
};

// Function to run quiz
int runQuiz(struct Question q[]) {
    int score = 0;
    char ans;

    for (int i = 0; i < Q; i++) {
        printf("\nQ%d: %s\n", i+1, q[i].ques);
        printf("A. %s\nB. %s\nC. %s\nD. %s\n", 
                q[i].optA, q[i].optB, q[i].optC, q[i].optD);

        printf("Your answer: ");
        scanf(" %c", &ans);

        if (ans == q[i].correct) {
            printf("Correct!\n");
            score++;
        } else {
            printf("Wrong! Correct = %c\n", q[i].correct);
        }
    }
    return score;
}

int main() {
    char name[50];
    int choice;

    // Questions (only few for simplicity)
    struct Question gk[Q] = {
        {"Capital of India?", "Mumbai", "Delhi", "Kolkata", "Chennai", 'B'},
        {"2 + 2 = ?", "3", "4", "5", "6", 'B'},
        {"Red Planet?", "Earth", "Venus", "Mars", "Jupiter", 'C'},
        {"Days in a week?", "5", "6", "7", "8", 'C'},
        {"Festival of lights?", "Holi", "Diwali", "Eid", "Pongal", 'B'}
    };

    struct Question cs[Q] = {
        {"Full form of CPU?", "Central Process Unit", "Central Processing Unit", "Computer Unit", "Control Unit", 'B'},
        {"Typing device?", "Monitor", "Keyboard", "Mouse", "Printer", 'B'},
        {"Output device?", "CPU", "Monitor", "Keyboard", "RAM", 'B'},
        {"Storage device?", "RAM", "CPU", "Mouse", "Keyboard", 'A'},
        {"Language used here?", "Java", "Python", "C", "C++", 'C'}
    };

    printf("Enter your name: ");
    scanf("%s", name);

    while (1) {
        printf("\n--- MENU ---\n");
        printf("1. GK Quiz\n2. CS Quiz\n3. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        if (choice == 3) {
            printf("Thank you %s!\n", name);
            break;
        }

        int score = 0;

        if (choice == 1) {
            score = runQuiz(gk);
        } else if (choice == 2) {
            score = runQuiz(cs);
        } else {
            printf("Invalid choice\n");
            continue;
        }

        printf("\nYour Score = %d/%d\n", score, Q);

        if (score == 5)
            printf("Excellent!\n");
        else if (score >= 3)
            printf("Good!\n");
        else
            printf("Average!\n");
    }

    return 0;
}
